<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_campaign"
                  targetNamespace="http://funnelier.ir/bpmn"
                  exporter="Funnelier"
                  exporterVersion="1.0">

  <!-- Messages -->
  <bpmn:message id="msg_delivery_complete" name="delivery_complete" />
  <bpmn:message id="msg_campaign_pause" name="campaign_pause" />
  <bpmn:message id="msg_campaign_resume" name="campaign_resume" />
  <bpmn:message id="msg_campaign_cancel" name="campaign_cancel" />

  <!-- Error definitions -->
  <bpmn:error id="err_sms_send_failed" name="SMS Send Failed" errorCode="SMS_SEND_FAILED" />

  <bpmn:process id="campaign_lifecycle" name="Campaign Lifecycle" isExecutable="true">

    <!-- Start: Campaign created -->
    <bpmn:startEvent id="start" name="Campaign Created">
      <bpmn:outgoing>flow_start_to_prepare</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- External task: Prepare recipient list -->
    <bpmn:serviceTask id="prepare_recipients" name="Prepare Recipients"
                      camunda:type="external" camunda:topic="prepare-campaign-recipients">
      <bpmn:incoming>flow_start_to_prepare</bpmn:incoming>
      <bpmn:outgoing>flow_prepare_to_gateway</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Gateway: Check if recipients exist -->
    <bpmn:exclusiveGateway id="gw_has_recipients" name="Has Recipients?">
      <bpmn:incoming>flow_prepare_to_gateway</bpmn:incoming>
      <bpmn:outgoing>flow_gw_to_send</bpmn:outgoing>
      <bpmn:outgoing>flow_gw_to_no_recipients</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- External task: Send SMS batch -->
    <bpmn:serviceTask id="send_sms_batch" name="Send SMS Batch"
                      camunda:type="external" camunda:topic="send-campaign-sms">
      <bpmn:incoming>flow_gw_to_send</bpmn:incoming>
      <bpmn:outgoing>flow_send_to_track</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Error boundary on SMS send: catches SMS_SEND_FAILED errors -->
    <bpmn:boundaryEvent id="boundary_sms_error" name="SMS Send Error"
                        attachedToRef="send_sms_batch">
      <bpmn:outgoing>flow_error_to_compensate</bpmn:outgoing>
      <bpmn:errorEventDefinition errorRef="err_sms_send_failed" />
    </bpmn:boundaryEvent>

    <!-- Compensation: handle partial send failures -->
    <bpmn:serviceTask id="compensate_sms" name="Compensate SMS Failure"
                      camunda:type="external" camunda:topic="compensate-sms-failure">
      <bpmn:incoming>flow_error_to_compensate</bpmn:incoming>
      <bpmn:outgoing>flow_compensate_to_end</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- End: Campaign failed with compensation -->
    <bpmn:endEvent id="end_compensated" name="Campaign Failed (Compensated)">
      <bpmn:incoming>flow_compensate_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- External task: Track delivery status -->
    <bpmn:serviceTask id="track_delivery" name="Track Delivery"
                      camunda:type="external" camunda:topic="track-sms-delivery">
      <bpmn:incoming>flow_send_to_track</bpmn:incoming>
      <bpmn:outgoing>flow_track_to_measure</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Stale delivery: timer if no delivery status in 24h -->
    <bpmn:boundaryEvent id="timer_stale_delivery" name="Stale Delivery (24h)"
                        attachedToRef="track_delivery" cancelActivity="false">
      <bpmn:outgoing>flow_stale_delivery_to_notify</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration>PT24H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:serviceTask id="notify_stale_delivery" name="Notify: Stale Delivery"
                      camunda:type="external" camunda:topic="notify-stale-stage">
      <bpmn:incoming>flow_stale_delivery_to_notify</bpmn:incoming>
      <bpmn:outgoing>flow_stale_delivery_end</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="end_stale_delivery">
      <bpmn:incoming>flow_stale_delivery_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- External task: Measure campaign results -->
    <bpmn:serviceTask id="measure_results" name="Measure Results"
                      camunda:type="external" camunda:topic="measure-campaign-results">
      <bpmn:incoming>flow_track_to_measure</bpmn:incoming>
      <bpmn:outgoing>flow_measure_to_complete</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- End: Campaign completed -->
    <bpmn:endEvent id="end_completed" name="Campaign Completed">
      <bpmn:incoming>flow_measure_to_complete</bpmn:incoming>
    </bpmn:endEvent>

    <!-- End: No recipients (campaign had no matching contacts) -->
    <bpmn:endEvent id="end_no_recipients" name="No Recipients">
      <bpmn:incoming>flow_gw_to_no_recipients</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Sequence Flows -->
    <bpmn:sequenceFlow id="flow_start_to_prepare" sourceRef="start" targetRef="prepare_recipients" />
    <bpmn:sequenceFlow id="flow_prepare_to_gateway" sourceRef="prepare_recipients" targetRef="gw_has_recipients" />
    <bpmn:sequenceFlow id="flow_gw_to_send" sourceRef="gw_has_recipients" targetRef="send_sms_batch">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${recipient_count &gt; 0}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_gw_to_no_recipients" sourceRef="gw_has_recipients" targetRef="end_no_recipients">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${recipient_count == 0}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_send_to_track" sourceRef="send_sms_batch" targetRef="track_delivery" />
    <bpmn:sequenceFlow id="flow_track_to_measure" sourceRef="track_delivery" targetRef="measure_results" />
    <bpmn:sequenceFlow id="flow_measure_to_complete" sourceRef="measure_results" targetRef="end_completed" />
    <!-- Compensation flows -->
    <bpmn:sequenceFlow id="flow_error_to_compensate" sourceRef="boundary_sms_error" targetRef="compensate_sms" />
    <bpmn:sequenceFlow id="flow_compensate_to_end" sourceRef="compensate_sms" targetRef="end_compensated" />
    <!-- Stale delivery flows -->
    <bpmn:sequenceFlow id="flow_stale_delivery_to_notify" sourceRef="timer_stale_delivery" targetRef="notify_stale_delivery" />
    <bpmn:sequenceFlow id="flow_stale_delivery_end" sourceRef="notify_stale_delivery" targetRef="end_stale_delivery" />

  </bpmn:process>

</bpmn:definitions>

