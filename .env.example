# Environment
ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production

# Application
APP_NAME=Funnelier
APP_VERSION=0.1.0
API_PREFIX=/api/v1

# Database - PostgreSQL (Primary)
DATABASE_URL=postgresql+asyncpg://funnelier:funnelier@localhost:5432/funnelier
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# MongoDB (for tenant data sources)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=funnelier_tenant

# JWT Settings
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# SMS Provider - Kavenegar (Default)
KAVENEGAR_API_KEY=your-kavenegar-api-key
KAVENEGAR_SENDER=your-sender-number

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# RFM Configuration (Default values, configurable per tenant)
RFM_RECENCY_DAYS_RECENT=14
RFM_MONETARY_HIGH_THRESHOLD=1000000000

# Funnel Configuration
FUNNEL_MIN_CALL_DURATION_SECONDS=90

# File Upload
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=["csv","xlsx","xls","json"]

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100

