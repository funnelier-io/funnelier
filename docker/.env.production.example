# Funnelier Production Environment Variables
# Copy to .env.production and fill in real values
# NEVER commit the actual .env.production file

# ── Application ──────────────────────────────────────
ENV=production
DEBUG=false
SECRET_KEY=CHANGE-ME-TO-RANDOM-64-CHAR-STRING
APP_NAME=Funnelier
APP_VERSION=0.1.0
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=WARNING
LOG_FORMAT=json

# ── CORS ─────────────────────────────────────────────
CORS_ORIGINS=["https://funnelier.ir","https://www.funnelier.ir"]

# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://funnelier:CHANGE_ME@postgres:5432/funnelier
DATABASE_POOL_SIZE=30
DATABASE_MAX_OVERFLOW=20

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=3600

# ── Celery ───────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── MongoDB (CRM/ERP data) ──────────────────────────
MONGODB_URL=mongodb://funnelier:CHANGE_ME@mongodb:27017
MONGODB_DATABASE=funnelier_tenant

# ── JWT Authentication ───────────────────────────────
JWT_SECRET_KEY=CHANGE-ME-TO-RANDOM-64-CHAR-STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Kavenegar SMS ────────────────────────────────────
KAVENEGAR_API_KEY=
KAVENEGAR_SENDER=
KAVENEGAR_WEBHOOK_SECRET=
KAVENEGAR_CALLBACK_URL=https://api.funnelier.ir/api/v1/webhooks/kavenegar/delivery

# ── Provider Selection ───────────────────────────────
MESSAGING_PROVIDER=kavenegar
ERP_PROVIDER=mongodb

# ── Rate Limiting ────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=200

# ── Docker Compose (used by docker-compose.prod.yml) ─
POSTGRES_USER=funnelier
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=funnelier
REGISTRY=ghcr.io
IMAGE_NAME=your-org/funnelier
TAG=latest
API_URL=https://api.funnelier.ir

